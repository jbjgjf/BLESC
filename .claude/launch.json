{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sentra-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "sentra/frontend"],
      "port": 3000
    },
    {
      "name": "sentra-backend",
      "runtimeExecutable": "sentra/backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000", "--app-dir", "sentra/backend"],
      "port": 8000
    }
  ]
}
